# Example configuration for local development.
# Copy this file to `.env` and adjust values for your machine.

# Optional application name used in greetings and logs.
APP_NAME=RAG Course Demo

# Optional default name used by the greeting command.
DEFAULT_NAME=World

# Optional environment label shown by the config command.
APP_ENV=development

# Optional verbose mode flag.
# Use `true` or `false`.
APP_VERBOSE=false

# OpenAI-compatible endpoint URL.
# Leave empty to use the library default.
OPENAI_BASE_URL=

# API token for the embedding endpoint.
# Use `OPENAI_API_KEY` for OpenAI and OpenAI-compatible services.
OPENAI_API_KEY=

# Embedding model to use for vector generation.
EMBEDDING_MODEL=text-embedding-3-small

# Qdrant REST endpoint.
# The local docker-compose file exposes Qdrant on port 9333.
QDRANT_URL=http://localhost:9333

# Qdrant collection name used by the import command.
QDRANT_COLLECTION_NAME=rag_chunks

# Dense vector length for the collection.
QDRANT_VECTOR_SIZE=1536

# Optional Qdrant API key.
QDRANT_API_KEY=
